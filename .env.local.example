# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/crm_local

# Uygulama ve oturum
APP_BASE_URL=http://localhost:3000
AUTH_COOKIE_NAME=pax_crm_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=12
AUTH_RESET_TTL_MINUTES=30

# Parola sıfırlama e-postası (opsiyonel)
AUTH_EMAIL_FROM=PAX CRM <noreply@example.com>
RESEND_API_KEY=

# Jira entegrasyonu (opsiyonel)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_RETAIL_SUPPORT_JQL=
JIRA_COMPANY_FIELD_ID=
JIRA_ORGANIZATION_FIELD_ID=

# Veritabanı yedeği (opsiyonel)
DB_BACKUP_DIR=./backups
PG_DUMP_PATH=pg_dump
