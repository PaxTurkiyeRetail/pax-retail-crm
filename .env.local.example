# PostgreSQL connection string. URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/crm_local

# Local authentication
AUTH_COOKIE_NAME=crm_session
AUTH_SESSION_TTL_HOURS=24
AUTH_RESET_TTL_MINUTES=30
AUTH_COOKIE_SECURE=true

# Optional Jira integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_RETAIL_SUPPORT_JQL=
JIRA_COMPANY_FIELD_ID=
JIRA_ORGANIZATION_FIELD_ID=

# Optional database backup settings
DB_BACKUP_DIR=/home/tahabitim/backups
PG_DUMP_PATH=/usr/lib/postgresql/16/bin/pg_dump
